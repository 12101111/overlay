From 340760b233d7827009e62034fc6ac2cb94f2a037 Mon Sep 17 00:00:00 2001
From: 12101111 <w12101111@gmail.com>
Date: Fri, 5 Jun 2026 21:26:07 +0800
Subject: [PATCH 12/14] remove @vscode/gulp-electron

---
 build/gulpfile.scan.ts | 12 ------------
 build/lib/electron.ts  |  2 --
 2 files changed, 14 deletions(-)

diff --git a/build/gulpfile.scan.ts b/build/gulpfile.scan.ts
index e89bde12bd1..e90b20d96db 100644
--- a/build/gulpfile.scan.ts
+++ b/build/gulpfile.scan.ts
@@ -7,8 +7,6 @@ import { gulp, filter } from './lib/gulp/facade.ts';
 import * as path from 'path';
 import * as task from './lib/gulp/task.ts';
 import * as util from './lib/util.ts';
-import electron from '@vscode/gulp-electron';
-import { config } from './lib/electron.ts';
 import * as deps from './lib/dependencies.ts';
 import { existsSync, readdirSync } from 'fs';
 
@@ -45,23 +43,13 @@ BUILD_TARGETS.forEach(buildTarget => {
 	// removal tasks
 	tasks.push(util.rimraf(destinationExe), util.rimraf(destinationPdb));
 
-	// electron
-	tasks.push(() => electron.dest(destinationExe, { ...config, platform, arch: arch === 'armhf' ? 'arm' : arch }));
-
 	// pdbs for windows
 	if (platform === 'win32') {
 		tasks.push(
-			() => electron.dest(destinationPdb, { ...config, platform, arch: arch === 'armhf' ? 'arm' : arch, pdbs: true }),
 			() => confirmPdbsExist(destinationExe, destinationPdb)
 		);
 	}
 
-	if (platform === 'linux') {
-		tasks.push(
-			() => electron.dest(destinationPdb, { ...config, platform, arch: arch === 'armhf' ? 'arm' : arch, symbols: true })
-		);
-	}
-
 	// node modules
 	tasks.push(
 		nodeModules(destinationExe, destinationPdb, platform)
diff --git a/build/lib/electron.ts b/build/lib/electron.ts
index 016c25f7553..ab819e5fee5 100644
--- a/build/lib/electron.ts
+++ b/build/lib/electron.ts
@@ -9,7 +9,6 @@ import vfs from 'vinyl-fs';
 import { filter, jsonEditor } from './gulp/facade.ts';
 import * as util from './util.ts';
 import { getVersion } from './getVersion.ts';
-import electron from '@vscode/gulp-electron';
 
 type DarwinDocumentSuffix = 'document' | 'script' | 'file' | 'source code';
 type DarwinDocumentType = {
@@ -222,7 +221,6 @@ function getElectron(arch: string): () => NodeJS.ReadWriteStream {
 
 		return vfs.src('package.json')
 			.pipe(jsonEditor({ name: product.nameShort }))
-			.pipe(electron(electronOpts))
 			.pipe(filter(['**', '!**/app/package.json']))
 			.pipe(vfs.dest('.build/electron'));
 	};
